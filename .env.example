# Copy to .env and fill in — `.env` is gitignored, never commit real secrets.
# Compose reads .env natively, and the pscale_exporter binary itself loads .env from
# the working directory (or next to config.yaml). Already-set environment variables
# always take precedence over .env values.

# Hostname or IP address of the OneFS cluster management endpoint.
# config.yaml references it as ${PSCALE1_HOSTNAME}.
PSCALE1_HOSTNAME=pscale-clu1.example.com

# Username of the read-only monitoring account (needs ISI_PRIV_STATISTICS + ISI_PRIV_QUOTA).
# config.yaml references it as ${PSCALE1_USERNAME}.
PSCALE1_USERNAME=pscale-monitor

# Password for the monitoring account. config.yaml references it as ${PSCALE1_PASSWORD}.
# Special characters: wrap the value in single quotes so it is taken literally, e.g.
# PSCALE1_PASSWORD='p@$$w0rd!#{}'. Double quotes expand $VAR and process backslashes;
# unquoted values treat " #" (space-hash) as a comment. For a literal ' use double
# quotes ("p'ass"); for a " use single quotes ('p"ass'); for both, a backslash, or a
# value starting with a quote, use passwordFile in config.yaml instead (read verbatim).
PSCALE1_PASSWORD=changeme

# Grafana admin credentials (optional — defaults to admin/admin for local stacks).
# GF_ADMIN_USER=admin
# GF_ADMIN_PASSWORD=changeme
