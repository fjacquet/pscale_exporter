    {
      "type": "table",
      "id": 12,
      "title": "Top Quotas (usage vs hard limit)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          },
          "unit": "bytes"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "used %"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "topk(25, powerscale_quota_usage_bytes{cluster=~\"$cluster\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "powerscale_quota_hard_threshold_bytes{cluster=~\"$cluster\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "B"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "cluster_id": true,
              "instance": true,
              "job": true,
              "quota_id": true
            },
            "renameByName": {
              "Value #A": "usage",
              "Value #B": "hard limit",
              "cluster": "cluster",
              "quota_path": "path",
              "quota_type": "type"
            }
          }
        }
      ],
      "description": "Quotas ranked by logical usage against their hard limit."
    },
