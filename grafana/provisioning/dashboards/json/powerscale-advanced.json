          "editorMode": "code",
          "expr": "powerscale_synciq_policy_enabled{cluster=~\"$cluster\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "powerscale_synciq_last_run_failed{cluster=~\"$cluster\"}",
          "format": "table",
          "instant": true,
          "refId": "B"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "cluster_id": true
            },
            "renameByName": {
              "Value #A": "enabled",
              "Value #B": "last run failed",
              "policy": "policy",
              "cluster": "cluster"
            }
          }
        }
      ],
      "description": "SyncIQ replication policies with enabled state and last-run result."
