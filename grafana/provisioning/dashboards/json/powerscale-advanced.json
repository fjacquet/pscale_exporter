      "panels": [
        {
          "type": "timeseries",
          "id": 12,
          "title": "Cache Read Hit vs Miss (L1/L2/L3)",
          "description": "L1/L2/L3 cache read hit vs miss throughput. Provisional: stat keys not yet live-validated against an OneFS cluster.",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 42
          },
          "fieldConfig": {
            "defaults": {
              "custom": {
                "drawStyle": "line",
                "fillOpacity": 10,
                "lineWidth": 1,
                "showPoints": "never",
                "stacking": {
                  "mode": "none"
                }
              },
              "unit": "Bps"
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": [
                "lastNotNull",
                "max",
                "mean"
              ]
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
              },
              "editorMode": "code",
              "expr": "sum by (cluster) (powerscale_node_cache_l1_read_hit_bytes_per_second{cluster=~\"$cluster\"})",
              "legendFormat": "{{cluster}} L1 hit",
              "refId": "A"
            },
            {
              "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
              },
              "editorMode": "code",
              "expr": "sum by (cluster) (powerscale_node_cache_l2_read_hit_bytes_per_second{cluster=~\"$cluster\"})",
              "legendFormat": "{{cluster}} L2 hit",
              "refId": "B"
            },
